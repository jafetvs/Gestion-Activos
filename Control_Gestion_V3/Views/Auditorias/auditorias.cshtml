
@{
    ViewBag.Title = "auditorias";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="card-body">
    <div id="estadisticasEstados" class="mb-3 d-flex justify-content-center flex-wrap gap-2">
        <span class="badge bg-dark">Total Casos: <span id="totalGeneral">0</span></span>
        <span class="badge bg-primary"> Registrado: <span id="totalRegistrado">0</span></span>
        <span class="badge bg-warning text-dark">En Proceso: <span id="totalEnProceso">0</span></span>
        <span class="badge bg-secondary">Total visibles: <span id="totalFiltrados">0</span></span>
    </div>

    <div class="row mt-3">
        <div class="col-12">
            <table id="tbdata" class="table table-striped table-bordered nowrap compact" style="width:100%">
                <thead class="table-primary">
                    <tr>
                        <th>#</th>
                        <th>Cédula Usuario</th>
                        <th>Rol</th>
                        <th>Tabla</th>
                        <th>Procedimiento</th>
                        <th>ID Columna Afectada</th>
                        <th>Modificación (JSON)</th>
                        <th>Fecha Modificación</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>

</div>
<div class="card-footer">
</div>


@section scripts {
    <script src="@Url.Content("~/Scripts/Views/Vista_Auditorias.js")" type="text/javascript"></script>
}