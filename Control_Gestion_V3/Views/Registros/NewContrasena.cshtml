

@{
    var correo = Request["correo"];

    Layout = null;
}

<html>
<head>
    <link href="//maxcdn.bootstrapcdn.com/bootstrap/3.3.0/css/bootstrap.min.css" rel="stylesheet" id="bootstrap-css">

    <link href="~/Content/css/loginCss.css" rel="stylesheet" />
    <meta name="viewport" content="width=device-width" />
    <title>Index</title>
    <style>
        body, html {
            height: 100%;
            background-repeat: no-repeat;
            /* background-image: linear-gradient(rgb(104, 145, 162), rgb(12, 97, 33)); */
        }

        .login-title {
            text-align: center;
            margin-top: 40px;
        }

        .navbar-header {
            top: 0;
            width: 100%;
            background-color: #338427;
            border-color: #1a4813;
        }

        .navbar-brand {
            height: 50px;
            padding: 15px 15px;
            font-size: 18px;
            line-height: 20px;
            color: yellow;
            text-align: center;
        }

        .card-container.card {
            max-width: 350px;
            padding: 40px 40px;
        }

        .card {
            background-color: #F7F7F7;
            padding: 20px 25px 30px;
            margin: 0 auto 25px;
            margin-top: 40px;
            border-radius: 2px;
            box-shadow: 0px 2px 2px rgba(0, 0, 0, 0.3);
        }

        .logo-container {
            margin-bottom: 30px;
        }

        .form-control,
        .password-container,
        .btn-signin {
            margin-bottom: 15px;
        }

        .password-container {
            position: relative;
            width: 100%;
        }

            .password-container input.form-control {
                padding-right: 40px; /* espacio para el ícono */
                height: 38px;
                box-sizing: border-box;
            }

        .toggle-password {
            position: absolute;
            top: 50%;
            right: 10px;
            transform: translateY(-50%);
            background: none;
            border: none;
            cursor: pointer;
            font-size: 18px;
            padding: 0;
            color: #000;
            line-height: 1;
            z-index: 10;
        }

            .toggle-password i {
                pointer-events: none;
            }

        .btn {
            font-weight: 700;
            height: 36px;
            user-select: none;
            cursor: pointer;
        }

        /* 🔻 Contenedor específico para mensajes de error de contraseña */
        .error-message {
            margin-top: -10px;
            margin-bottom: 15px;
            padding-left: 5px;
        }

        /* Mensajes de validación */
        span.text-danger {
            font-size: 1.5rem;
            color: red;
            display: block;
            margin-top: 4px;
        }
    </style>

</head>
<body>
    <div class="navbar-header">
        <p class="navbar-brand"> APPS-GESTIÓN DOCUMENTAL</p>
    </div>
    <hr />
    <div class="container">
        <div class="card card-container">
            <div class="text-center mb-4 mt-3">
                <a href="#">
                    <span><img src="@Url.Content("~/Imagenes/EscudoAtenas.png")" alt="" height="150"></span>
                </a>
            </div>
            @{
                var error = ViewBag.Error as string;
            }
        <form id="form" class="form-signin" action="@Url.Action("NewContrasena", "Registros")" method="post">
            <input type="hidden" id="correoHidden" name="correoHidden" value="@correo" />
            <!-- Código -->
            <div class="form-group">
                <label for="codigo">Código de recuperación</label>
                <input class="form-control" type="number" name="codigo" id="codigo" required>
            </div>
            <!-- Contraseña -->
            <div class="password-container mb-0">
                <input class="form-control" type="password" name="inputPassword" id="inputPassword" placeholder="Contraseña" spellcheck="false" required>
                <button type="button" class="toggle-password" onclick="togglePassword('inputPassword', 'icon1')">
                    <i id="icon1" class="fas fa-lock"></i>
                </button>
            </div>
            <!-- Mensaje de error separado -->
            <div class="error-message mb-3">
                <span id="errorPassword"></span>
            </div>

            <!-- Confirmar Contraseña -->
            <div class="password-container mb-0">
                <input class="form-control" type="password" name="inputPasswordConfirm" id="inputPasswordConfirm" placeholder="Confirmar Contraseña" spellcheck="false" required>
                <button type="button" class="toggle-password" onclick="togglePassword('inputPasswordConfirm', 'icon2')">
                    <i id="icon2" class="fas fa-lock"></i>
                </button>
            </div>
            <!-- Mensaje de error separado -->
            <div class="error-message mb-3">
                <span id="errorPasswordConfirm"></span>
            </div>

            <button class="btn btn-lg btn-primary btn-block btn-signin" type="submit">Ingresar</button>
        </form>


            <p class="register-link">¿No tienes una cuenta? <a href="@Url.Content("~/Registros/CrearCuenta")">Regístrate aquí</a></p>

        </div><!-- /card-container -->
        <div class="row mt-4">
            <div class="col-sm-12 text-center">
                <p class="text-white mb-0">
                    Todos los derechos reservados &copy;<a href="https://www.atenasmuni.go.cr" target="_blank" class="text-white ml-1">
                        <b>Tecnologías de Información -</b>
                        <b> Municipalidad Atenas</b>
                    </a>
                </p>
            </div>
        </div>
    </div><!-- /container -->
    @Scripts.Render("~/bundles/jquery")
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.5/dist/jquery.validate.min.js"></script>

    @Scripts.Render("~/bundles/modernizr")
    @Scripts.Render("~/bundles/Complementos")
    @Scripts.Render("~/Content/PluginsJS")
    @Scripts.Render("~/bundles/fullcalendar")
    @Scripts.Render("~/bundles/bootstrap")

    <script src="@Url.Content("~/Scripts/Views/Vistas_Registros.js")" type="text/javascript"></script>



</body>
</html>
