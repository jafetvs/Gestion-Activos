
@{
    ViewBag.Title = "rol";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@section estilos{
    <style>
        .custom-header {
            background-color: #53a87c; /* Color de fondo deseado */
            color: white; /* Color del texto */
            padding: 10px; /* Opcional: añadir espaciado */
            border-radius: 4px; /* Opcional: bordes redondeados */
            text-align: center; /* Opcional: centrar texto */
        }
    </style>
}
<div class="col-lg-12 mt-4">
    <h3 class="page-header">
        <span id="chpPrincipal_lblTitulo">Configuración de Roles </span>
    </h3>
    <ol class="breadcrumb">
        <li class="me-3">
            <i class="fas fa-address-card me-1"></i>
            <a href="@Url.Action("usuario", "Usuario")" style="text-decoration: none;">Usuarios</a>
        </li>
        <li class="active me-3">
            <i class="fas fa-user-lock me-1"></i>
            <a href="@Url.Action("permisos", "Permisos")" style="text-decoration: none;">Permisos</a>
        </li>
    </ol>
</div>
<div class="row">
    <div class="col-sm-12">
        <div class="card border-info">
            <div class="card-header d-flex justify-content-between custom-header">
                <div class="d-flex align-items-center">
                    <i class="fas fa-table me-1"></i>
                    <span>Tablas Roles</span>
                </div>

                <button type="button" class="btn btn-sm btn-success" onclick="abrirPopUpForm(null)">
                    <i class="fa fa-plus" aria-hidden="true"></i> Agregar Nuevo
                </button>
            </div>
            <div class="card-body">
                <div class="row mt-2">
                    <div class="col-sm-12">
                        <table id="tbdata" class="table table-striped table-bordered nowrap compact" style="width:100%">
                            <thead>
                                <tr>
                                    <th>Descripcion</th>
                                    <th>Estado</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal -->
<div class="modal fade" id="FormModal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header bg-info text-white">
                <h5 class="modal-title" id="exampleModalLabel">Rol</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="form">
                    <input id="txtid" class="model" value="0" type="hidden" />
                    <div class="mb-3">
                        <label for="txtDescripcion" class="col-form-label">Descripcion: <span class="error"></span></label>
                        <input type="text" class="form-control form-control-sm model required" id="txtDescripcion" name="Descripcion">
                    </div>
                    <div class="mb-3">
                        <label for="cboEstado" class="col-form-label">Activo:</label>
                        <select class="form-control form-control-sm model" id="cboEstado" name="Activo">
                            <option value="1">Activo</option>
                            <option value="0">No Activo</option>
                        </select>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-sm btn-danger" data-bs-dismiss="modal">Cerrar</button>
                <button id="btnGuardarCambios" type="button" class="btn btn-sm btn-primary" onclick="Guardar()">Guardar</button>
            </div>
        </div>
    </div>
</div>



@section scripts{
    <script src="@Url.Content("~/Scripts/Views/Vista_Rol.js")" type="text/javascript"></script>
}


