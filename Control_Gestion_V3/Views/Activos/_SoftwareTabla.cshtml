@using CapaModelo
@model IEnumerable<CapaModelo.ActivoSoftware>

@{
    // Paginaciµn (igual que en movimientos)
    int page = ViewBag.Page is int ? (int)ViewBag.Page : 1;
    int totalPages = ViewBag.TotalPages is int ? (int)ViewBag.TotalPages : 1;

    string F(object v) => (v == null || string.IsNullOrWhiteSpace(v.ToString())) ? "" : v.ToString();
    Func<DateTime?, string> Fec = d => d.HasValue ? d.Value.ToString("dd/MM/yyyy") : "";
    Func<DateTime, string> FecFull = d => d.ToString("dd/MM/yyyy HH:mm");
}

@if (Model == null || !Model.Any())
{
    <div class="alert alert-light text-muted m-0">Sin software registrado.</div>
}
else
{
    <div class="list-group">
        @foreach (var s in Model)
        {
            <div class="list-group-item list-group-item-action d-flex gap-3 py-3">
                <div class="rounded-circle bg-light border flex-shrink-0 d-flex align-items-center justify-content-center" style="width:40px;height:40px;">
                    <i class="fas fa-laptop-code"></i>
                </div>

                <div class="w-100">
                    <div class="d-flex justify-content-between align-items-start">
                        <div class="fw-semibold">
                            @Html.Raw(
                                F(s.Nombre) + (string.IsNullOrWhiteSpace(s.Version) ? "" : "  Versiµn: " + s.Version)
                            )
                        </div>
                        <small class="text-muted">
                            @Fec(s.FechaInstalacion)
                        </small>
                    </div>

                    <div class="small text-muted">
                        Editor: @Html.Raw(F(s.Editor)) ñ Tamaþo: @Html.Raw(F(s.Tamano))
                    </div>

                    <div class="small text-muted mt-1">
                        Registrado por el Usuario con ID: @Html.Raw((s.IdUsuarioCrea > 0) ? s.IdUsuarioCrea.ToString() : "")
                        - @Html.Raw(FecFull(s.FechaRegistro))
                    </div>

                    <div class="mt-2 d-flex justify-content-end">
                        <button class="btn btn-sm btn-outline-secondary"
                                title="Editar"
                                onclick="abrirModalSoftware({ idSoftware: @s.IdSoftware, idActivo: @s.IdActivo })">
                            <i class="fas fa-edit"></i>
                        </button>
                        <button class="btn btn-sm btn-outline-danger ms-1"
                                title="Eliminar"
                                onclick="eliminarSoftware(@s.IdSoftware)">
                            <i class="fas fa-trash-alt"></i>
                        </button>
                    </div>
                </div>
            </div>
        }
    </div>

    if (totalPages > 1)
    {
        <nav class="mt-2">
            <ul class="pagination pagination-sm justify-content-end mb-0">
                <li class="page-item @(page<=1 ? "disabled" : "")">
                    <a class="page-link" href="javascript:void(0)" onclick="sw_irPagina(@(page-1))" aria-label="Anterior">&laquo;</a>
                </li>

                @for (int i = 1; i <= totalPages; i++)
                {
                    <li class="page-item @(i==page ? "active" : "")">
                        <a class="page-link" href="javascript:void(0)" onclick="sw_irPagina(@i)">@i</a>
                    </li>
                }

                <li class="page-item @(page>=totalPages ? "disabled" : "")">
                    <a class="page-link" href="javascript:void(0)" onclick="sw_irPagina(@(page+1))" aria-label="Siguiente">&raquo;</a>
                </li>
            </ul>
        </nav>
    }
}
