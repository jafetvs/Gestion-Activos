@section scripts{
    <script>
        (function () {
            function getQS(name) {
                var m = new RegExp('[?&]' + name + '=([^&#]*)').exec(location.search);
                return m ? decodeURIComponent(m[1].replace(/\+/g, ' ')) : null;
            }
            function activateFromQSorHash() {
                var map = {
                    "resumen": "tab-resumen",
                    "compra": "tab-compra",
                    "hardware": "tab-hw",
                    "software": "tab-sw",
                    "mantenimientos": "tab-mnt",
                    "movimientos": "tab-mov",
                    "adjuntos": "tab-adj"
                };
                var tabQS = (getQS('tab') || '').toLowerCase();
                var btnId = map[tabQS];
                if (!btnId) {
                    var hash = (window.location.hash || "#resumen").toLowerCase().replace('#', '');
                    btnId = map[hash] || "tab-resumen";
                }
                var btn = document.getElementById(btnId);
                if (btn) new bootstrap.Tab(btn).show();
            }
            window.addEventListener('hashchange', activateFromQSorHash);
            document.addEventListener('DOMContentLoaded', function () {
                activateFromQSorHash();
                var tabs = document.querySelectorAll('#tabsActivo [data-bs-toggle="tab"]');
                tabs.forEach(function (t) {
                    t.addEventListener('shown.bs.tab', function (ev) {
                        var target = ev.target.getAttribute('data-bs-target');
                        var hash = "#resumen";
                        if (target === "#pane-compra") hash = "#compra";
                        else if (target === "#pane-hw") hash = "#hardware";
                        else if (target === "#pane-sw") hash = "#software";
                        else if (target === "#pane-mnt") hash = "#mantenimientos";
                        else if (target === "#pane-mov") hash = "#movimientos";
                        else if (target === "#pane-adj") hash = "#adjuntos";
                        history.replaceState(null, "", hash);
                    });
                });

                // ====== Lógica de cambio de proveedor (opcional) ======
                var btnToggle = document.getElementById('btnToggleProveedor');
                var zona = document.getElementById('zonaCambioProveedor');
                var sel = document.getElementById('selProveedor');
                var btnAplicar = document.getElementById('btnAplicarProveedor');
                var btnCancelar = document.getElementById('btnCancelarProveedor');

                if (btnToggle && zona && sel) {
                    btnToggle.addEventListener('click', function () {
                        zona.style.display = (zona.style.display === 'none' || zona.style.display === '') ? 'block' : 'none';
                    });
                }

                function setHiddenProveedor(val) {
                    var hidden = document.querySelector('input[type="hidden"][name="IdProveedor"]');
                    if (hidden) hidden.value = val || '';
                }

                if (btnAplicar && sel) {
                    btnAplicar.addEventListener('click', function () {
                        setHiddenProveedor(sel.value);
                        zona.style.display = 'none';
                    });
                }
                if (btnCancelar && sel) {
                    btnCancelar.addEventListener('click', function () {
                        var hidden = document.querySelector('input[type="hidden"][name="IdProveedor"]');
                        if (hidden) sel.value = hidden.value || '';
                        zona.style.display = 'none';
                    });
                }
            });
        })();
    </script>

