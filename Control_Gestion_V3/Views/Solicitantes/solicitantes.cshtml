
@{
    ViewBag.Title = "solicitantes";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="col-lg-12 mt-4">
    <h3 class="page-header">
        <span id="chpPrincipal_lblTitulo">Configuración de Contribuyentes</span>
    </h3>
    <ol class="breadcrumb">
        <li class="me-3">
            <i class="fas fa-address-card me-1"></i>
            <a href="@Url.Action("usuario", "Usuario")" style="text-decoration: none;">Usuarios</a>
        </li>
        <li class="active me-3">
            <i class="fas fa-ticket-alt"></i>
            <a href="@Url.Action("casos", "Casos")" style="text-decoration: none;">Casos</a>
        </li>
    </ol>
</div>
<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between custom-header">
                <div class="d-flex align-items-center">
                    <i class="fas fa-table me-1"></i>
                    <span>Contribuyentes</span>
                </div>
                <button type="button" class="btn btn-sm btn-success" onclick="abrirPopUpForm(null)">
                    <i class="fa fa-plus" aria-hidden="true"></i> Agregar Nuevo
                </button>
            </div>
            <div class="card-body">
                <hr />
                <div class="row mt-3">
                    <div class="col-12">
                        <table id="tbdata" class="table table-striped table-bordered nowrap compact" style="width:100%">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Tipo documento</th>
                                    <th>Documento</th>
                                    <th>Nombre de Usuario</th>
                                    <th>Dirección</th>
                                    <th>Teléfono</th>
                                    <th>Teléfono 2</th>
                                    <th>Fax</th>
                                    <th>Correo</th>
                                    <th>Fecha Registro</th>
                                    <th>Estado</th>
                                    <th>Acciones</th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>
            </div>
            <div class="card-footer">
                <!-- Puedes agregar contenido aquí si lo deseas -->
            </div>
        </div>
    </div>
</div>

<!-- Modal -->
<div class="modal fade" id="FormModal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-info text-white">
                <h3 class="modal-title" id="exampleModalLabel">
                    <img src="~/Imagenes/Crear.png" alt="Icono" style="width: 30px; height: 30px; vertical-align: middle; margin-right: 5px;">
                    Datos Solicitantes
                </h3>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="form">
                    <input id="txtid" class="model" value="0" type="hidden" />
                    <!-- Tipo de documento-->
                    <div class="mb-3 row">
                        <label for="cbotipodocumento" class="col-sm-4 col-form-label col-form-label-sm">Tipo Documento</label>
                        <div class="col-sm-8">
                            <select class="form-control form-control-sm model" id="cbotipodocumento">
                                <option value="DNI">DNI</option>
                                <option value="Carnet Extranjeria">Carnet Extranjeria</option>
                                <option value="RUC">RUC</option>
                            </select>
                        </div>
                    </div>
                    <!-- Cédula o número de documento -->
                    <div class="mb-3 row">
                        <label for="inputCedula" class="col-sm-3 col-form-label col-form-label-sm">Identificación</label>
                        <div class="col-sm-9">
                            <input type="text" class="form-control form-control-sm model" id="inputCedula" name="Cedula">
                            <!-- Mensaje de error -->
                        </div>
                    </div>

                    <!-- Nombre -->
                    <div class="mb-3 row">
                        <label for="txtNombre" class="col-sm-2 col-form-label col-form-label-sm">Nombre</label>
                        <div class="col-sm-10">
                            <input type="text" class="form-control form-control-sm model" id="txtNombre" name="Nombre">
                        </div>
                    </div>
                    <!-- Dirección -->
                    <div class="mb-3 row">
                        <label for="txtDireccio" class="col-sm-2 col-form-label col-form-label-sm">
                            Dirección
                            <span class="error"></span>
                        </label>
                        <div class="col-sm-10">
                            <input type="text" class="form-control form-control-sm model" id="txtDireccion" name="Direccion">
                        </div>
                    </div>
                    <!-- Teléfono -->
                    <div class="mb-3 row">
                        <label for="inputTelefono" class="col-sm-2 col-form-label col-form-label-sm">Teléfono</label>
                        <div class="col-sm-10">
                            <input type="number" class="form-control form-control-sm model" id="inputTelefono" name="telefono">
                            <!-- Mensaje de error -->
                        </div>
                    </div>
                    <!-- Fax-->
                    <div class="mb-3 row">
                        <label for="inputFax" class="col-sm-2 col-form-label col-form-label-sm">Fax</label>
                        <div class="col-sm-10">
                            <input type="number" class="form-control form-control-sm model" id="inputFax" name="fax">
                            <!-- Mensaje de error -->
                        </div>
                    </div>
                    <!-- Correo -->
                    <div class="mb-3 row">
                        <label for="txtCorreo" class="col-sm-2 col-form-label col-form-label-sm">Correo </label>
                        <div class="col-sm-10">
                            <input type="text" class="form-control form-control-sm model" id="txtCorreo" name="Correo">
                        </div>
                    </div>

                    <div class="mb-3 row">
                        <label for="cboEstado" class="col-sm-2 col-form-label col-form-label-sm">Activo</label>
                        <div class="col-sm-10">
                            <select class="form-control form-control-sm model" id="cboEstado" name="Activo">
                                <option value="1">Activo</option>
                                <option value="0">No Activo</option>
                            </select>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-sm btn-danger" data-bs-dismiss="modal">  <i class="fas fa-window-close"> </i> Cerrar</button>
                <button id="btnGuardarCambios" type="button" class="btn btn-sm btn-primary" onclick="Guardar()"> <i class="fas fa-save"> </i> Guardar</button>
            </div>
        </div>
    </div>
</div>



@section scripts{
    <script src="@Url.Content("~/Scripts/Views/Vista_Solicitantes.js")" type="text/javascript"></script>
}

