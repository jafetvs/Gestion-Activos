
@{
    ViewBag.Title = "EditarSolicitante";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<link href="~/Content/css/EditarUsuario.css" rel="stylesheet" />

<div id="page-wrapper">
    <div class="container-fluid">
        <div id="UpdatePanel1">
            <!-- Page Heading -->
            <div class="row">
                <div class="col-lg-12">
                    <h3 class="page-header">
                        <span>Detalles del Solicitante </span>
                    </h3>
                    <ol class="breadcrumb">
                        <li class="me-3">
                            <i class="fas fa-address-card"></i> <a href="@Url.Action("usuario", "Usuario")">Usuarios</a>
                        </li>
                        <li class="active me-3">
                            <i class="fa fa-adjust"></i> <a href="@Url.Action("permisos", "Permisos")">Permisos</a>
                        </li>
                    </ol>

                </div>
                <div class="col-lg-12">
                    <div class="wrapper text-center">
                        <span id="chpPrincipal_lblMensaje" class="error-msg"></span>
                        <div id="chpPrincipal_valMensajes" class="error-msg" style="display:none;">
                            <!-- Mensajes de error -->
                        </div>
                    </div>
                </div>
                <div class="tab-content">
                    <div id="sectionA">
                        <div class="row">
                            <div class="col-lg-12">
                                <br />
                            </div>
                        </div>
                        <form id="form">
                            <div class="row">
                                <div class="col-lg-4">
                                    <div class="mb-3">
                                        <label for="txtIdentificacion" class="form-label">Código Usuario</label>
                                        <div class="input-group">
                                            <input name="txtid" type="text" value=""
                                                   id="txtid" disabled class="form-control" />
                                        </div>
                                    </div>
                                    <div class="mb-3">
                                        <label for="txtIdentificacion" class="form-label">Identificación</label>
                                        <div class="input-group">
                                            <input name="txtinputCedula" type="text" value=""
                                                   id="inputCedula" disabled class="form-control" />
                                        </div>
                                    </div>
                                    <div class="mb-3">
                                        <label for="txtNombre" class="form-label">Nombre</label>
                                        <input type="text" class="form-control" id="txtNombre">
                                    </div>
                                    <div class="mb-3">
                                        <label for="inputTelefono" class="form-label">Teléfono 1</label>
                                        <input type="text" class="form-control" id="inputTelefono">
                                    </div>

                                    <div class="mb-3">
                                        <label for="txtCorreo" class="form-label">Correo Electrónico</label>
                                        <input type="email" class="form-control" id="txtCorreo" placeholder="Formato correo Ej. correo@dominio.com">
                                    </div>

                                </div>

                                <div class="col-lg-4">
                                    <div class="mb-3 row">
                                        <label for="cbotipodocumento" class="form-label">Tipo Documento</label>
                                        <select class="form-control form-control-sm model" id="cbotipodocumento">
                                            <option value="DNI">DNI</option>
                                            <option value="Carnet Extranjeria">Carnet Extranjeria</option>
                                            <option value="RUC">RUC</option>
                                        </select>
                                    </div>

                                    <div class="mb-3">
                                        <label for="txtTelefono" class="form-label">Teléfono 2</label>
                                        <input name="inputTelefono2" type="text" maxlength="20" id="inputTelefono2"
                                               class="form-control" placeholder="Ingrese teléfono" />
                                    </div>

                                    <div class="mb-3">
                                        <label for="inputFax" class="form-label">Fax</label>
                                        <input type="text" class="form-control" id="inputFax">
                                    </div>

                                    <div class="mb-3">
                                        <label for="txtDireccion" class="form-label">Dirección</label>
                                        <textarea class="form-control" id="txtDireccion" rows="4" cols="20" placeholder="Ingrese dirección"></textarea>
                                    </div>
                                </div>

                                <div class="col-lg-4">
                                    <div class="mb-3">
                                        <label for="chpPrincipal_txtImagen" class="form-label">Fotografía:</label>
                                        <img id="chpPrincipal_txtImagen" class="img-responsive" alt="No disponible." src="~/Imagenes/NODISPONIBLE.jpg" style="height:103px;width:111px;" />

                                    </div>

                                    <div class="mb-3">
                                        <label for="chpPrincipal_RadAsyncUpload1" class="form-label">Seleccionar archivo</label>
                                        <div id="ctl00_chpPrincipal_RadAsyncUpload1" class="RadAsyncUpload RadUpload RadUpload_Default">
                                            <input id="ctl00_chpPrincipal_RadAsyncUpload1_ClientState" name="ctl00_chpPrincipal_RadAsyncUpload1_ClientState" type="hidden" />
                                        </div>
                                        <button type="submit" class="btn btn-danger btn-sm" id="chpPrincipal_btnSubirFoto">Enviar</button>
                                    </div>
                                    <div class="mb-3">
                                        <label for="txtFechaRegistro" class="form-label">Fecha de Registro</label>
                                        <input type="text" class="form-control" id="txtFechaRegistro" disabled>
                                    </div>
                                    <div class="mb-3">
                                        <label for="txtEstado" class="form-label">Estado usuario</label>
                                        <select class="form-control form-control-sm model" id="cboEstado" name="Activo">
                                            <option value="1">Activo</option>
                                            <option value="0">No Activo</option>
                                        </select>
                                    </div>

                                </div>
                            </div>

                            <!-- /.row -->
                            <div class="row">
                                <div class="col-lg-12">
                                    <div class='wrapper text-center'>
                                        <div class="btn-group">
                                            <button id="btnGuardarCaso" type="button" class="btn btn-success" onclick="Guardar()">Actializar</button>

                                        </div>
                                        <div class="btn-group">
                                            <button id="btnGuardarCaso" type="button" class="btn btn-success" onclick="Cancelar()">Cancelar</button>
                                        </div>
                                    </div>

                                </div>
                            </div>
                            <!-- /.row -->
                        </form>



                    </div>
                </div>
            </div>
        </div>

    </div>
</div>


@section scripts{
    <script src="@Url.Content("~/Scripts/Views/Vista_EditarSolicitante.js")" type="text/javascript"></script>
}


