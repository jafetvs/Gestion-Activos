
@{
    string cedula = ViewBag.Cedula_Usuario;
    ViewBag.Title = "perfil";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<style>
    h1 {
        text-align: center;
        font-size: 2.5em;
        color: #333;
        margin-bottom: 20px;
    }

    .container {
        width: 90%;
        max-width: 900px;
        background: white;
        padding: 20px;
        border-radius: 10px;
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
        /**/
    }

    .d-flex {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .col-5 {
        width: 45%;
    }

    .form-label {
        font-weight: bold;
    }
</style>
<style>
   
    .password-container {
        position: relative;
        width: 100%;
    }

        .password-container input.form-control {
            padding-right: 40px; /* espacio para el ícono */
            height: 38px;
            box-sizing: border-box;
        }

    .toggle-password {
        position: absolute;
        top: 50%;
        right: 10px;
        transform: translateY(-50%);
        background: none;
        border: none;
        cursor: pointer;
        font-size: 18px;
        padding: 0;
        color: #000;
        line-height: 1;
        z-index: 10;
    }

        .toggle-password i {
            pointer-events: none;
        }
    /* 🔻 Contenedor específico para mensajes de error de contraseña */
    .error-message {
        margin-top: -10px;
        margin-bottom: 15px;
        padding-left: 5px;
    }

    /* Mensajes de validación */
    span.text-danger {
        font-size: 15px;
        color: red;
        display: block;
        margin-top: 15px;
    }
</style>
<div class="container">
    <div class="card" style="background-color: #f3f3f7; margin-top: 10px; ">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h3>Datos solicitante</h3>
            <i class="fas fa-user-circle fa-4x"></i>
        </div>

        <div id="infoAdicional2" class="card-body">
            <div class="form-group">
                <form id="form">
                    <!-- Contenedor con dos columnas -->
                    <input type="hidden" id="cedulaUsuario" value="@ViewBag.Cedula_Usuario" />
                    <div class="mb-3 d-flex justify-content-between">
                        <div class="col-5">
                            <label for="txtIdentificacion" class="form-label">Código Usuario</label>
                            <input name="txtinputCedula" type="text" value=""
                                   id="inputIdUsuario" disabled class="form-control" />
                        </div>

                        <div class="col-4">
                            <label for="#txtNom_User" class="form-label">Tipo Usuario (No editabla)</label>
                            <input type="text" class="form-control" id="cboRol" name="Rol" disabled>
                        </div>
                    </div>
                    <input type="hidden" class="form-control form-control-sm model" id="txtNom_Rol" name="Nom_Rol" />

                    <!-- Contenedor con dos columnas (Correo y Teléfono) -->
                    <div class="mb-3 d-flex justify-content-between">
                        <!-- Columna Izquierda: Nombre -->
                        <div class="col-5">
                            <label for="#txtNom_User" class="form-label">Usuario</label>
                            <input type="text" class="form-control" id="txtNombre_User">
                        </div>
                        <div class="col-4">
                            <label for="txtEstado" class="form-label">Estado (No editabla)</label>
                            <select class="form-control form-control-sm model" id="cboEstado" name="Activo" disabled>
                                <option value="1">Activo</option>
                                <option value="0">No Activo</option>
                            </select>
                        </div>

                    </div>
                    <!-- Contenedor con dos columnas -->
                    <div class="mb-3 d-flex justify-content-between">
                        <!-- Columna Izquierda: Nombre -->
                        <div class="col-5">
                            <label for="txtNombre" class="form-label">Nombre</label>
                            <input type="text" class="form-control" id="txtNombre">
                        </div>
                        <!-- Columna Derecha: Identificación -->
                        <div class="col-4">
                            <label for="inputCedula" class="form-label">Identificación (No editabla)</label>
                            <input type="text" class="form-control" id="inputCedula" disabled>
                        </div>
                    </div>

                    <!-- Contenedor con dos columnas (Correo y Teléfono) -->
                    <div class="mb-3 d-flex justify-content-between">
                        <div class="col-5">
                            <label for="txtCorreo" class="form-label">Correo Electrónico</label>
                            <input type="email" class="form-control" id="txtCorreo">
                        </div>
                        <div class="col-4">
                            <label for="inputFax" class="form-label">Fax</label>
                            <input type="text" class="form-control" id="inputFax">
                        </div>

                    </div>

                    <!-- Contenedor con dos columnas (Teléfono y Fax) -->
                    <div class="mb-3 d-flex justify-content-between">
                        <div class="col-5">
                            <label for="inputTelefono" class="form-label">Teléfono</label>
                            <input type="text" class="form-control" id="inputTelefono">
                        </div>
                        <div class="col-4">
                            <label for="txtTelefono" class="form-label">Teléfono 2</label>
                            <input name="inputTelefono2" type="text" maxlength="20" id="inputTelefono2"
                                   class="form-control" placeholder="Ingrese teléfono" />
                        </div>
                    </div>
                    <!-- Contenedor Dirección -->
                    <div class="col-md-12">
                        <div class="mb-3">
                            <label for="txtDireccion" class="form-label">Dirección</label>
                            <textarea class="form-control" id="txtDireccion" rows="3"></textarea>
                        </div>
                    </div>
                    <!-- Contraseñas -->
                    <div class="row mb-2">
                        <div class="col-md-6">
                            <div class="form-floating mb-3 mb-md-0">
                                <input name="inputPassword" type="password" maxlength="50" class="form-control"
                                       autocomplete="new-password" id="inputPassword" placeholder="Ingrese contraseña" />
                                <button type="button" class="toggle-password" onclick="togglePassword('inputPassword', 'icon1')">
                                    <i id="icon1" class="fas fa-lock"></i>
                                </button>
                                <label for="inputPassword">Contraseña</label>
                            </div>
                            <div class="error-message">
                                <span class="text-danger" id="errorPassword"></span>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="form-floating mb-3 mb-md-0">
                                <input name="inputPasswordConfirm" type="password" maxlength="50" class="form-control"
                                       id="inputPasswordConfirm" placeholder="Confirme contraseña" autocomplete="new-password" />
                                <button type="button" class="toggle-password" onclick="togglePassword('inputPasswordConfirm', 'icon2')">
                                    <i id="icon2" class="fas fa-lock"></i>
                                </button>
                                <label for="inputPasswordConfirm">Confirmar Contraseña</label>
                            </div>
                            <div class="error-message">
                                <span class="text-danger" id="errorPasswordConfirm"></span>
                            </div>
                        </div>
                    </div>
                    <!-- /.row -->
                    <div class="row">
                        <div class="col-lg-12">
                            <div class='wrapper text-center'>
                                <div class="btn-group">
                                    <button id="btnGuardarCaso" type="button" class="btn btn-success" onclick="Guardar()">Actializar</button>

                                </div>
                                <div class="btn-group">
                                    <button id="btnGuardarCaso" type="button" class="btn btn-success" onclick="Cancelar()">Cancelar</button>
                                </div>
                            </div>

                        </div>
                    </div>
                    <!-- /.row -->
                </form>
            </div>
        </div>
    </div>
</div>




@section scripts{
    <script src="@Url.Content("~/Scripts/Views/Vista_EditarUsuario.js")" type="text/javascript"></script>
    <script src="@Url.Content("~/Scripts/Views/Vista_Login.js")" type="text/javascript"></script>

}


