
@{

    ViewBag.Title = "usuario";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@section estilos{
    <style>
        .custom-header {
            background-color: #53a87c; /* Color de fondo deseado */
            color: white; /* Color del texto */
            padding: 10px; /* Opcional: añadir espaciado */
            border-radius: 4px; /* Opcional: bordes redondeados */
            text-align: center; /* Opcional: centrar texto */
        }
    </style>
}
<div class="col-lg-12 mt-4">
    <h3 class="page-header">
        <span>Detalles del Solicitante </span>
    </h3>
    <ol class="breadcrumb">
        <li class="me-3">
            <i class="fas fa-user-lock me-1"></i>
            <a href="@Url.Action("permisos", "Permisos")" style="text-decoration: none;">Permisos</a>
        </li>
        <li class="active me-3">
            <i class="fas fa-users me-1"></i>
            <a href="@Url.Action("rol", "Rol")" style="text-decoration: none;">Roles</a>
        </li>
    </ol>
</div>
<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between custom-header">
                <div class="d-flex align-items-center">
                    <i class="fas fa-table me-1"></i>
                    <span>Tabla Usuarios</span>
                </div>
                <button type="button" class="btn btn-sm btn-success" onclick="abrirPopUpForm(null)">
                    <i class="fa fa-plus" aria-hidden="true"></i> Agregar Nuevo
                </button>
            </div>
            <div class="card-body">
                <hr />
                <div class="row mt-3">
                    <div class="col-12">
                        <table id="tbdata" class="table table-striped table-bordered nowrap compact" style="width:100%">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Rol</th>
                                    <th>Cédula</th>
                                    <th>Usuario</th>
                                    <th>Nombre</th>
                                    <th>Correo</th>
                                    <th>Dirección</th>
                                    <th>Teléfono 1</th>
                                    <th>Teléfono 2</th>
                                    <th>Fax</th>
                                    <th>Fecha Registro</th>
                                    <th>Estado</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="card-footer">
                <!-- Puedes agregar contenido aquí si lo deseas -->
            </div>
        </div>
    </div>
</div>
<!-- Modal -->
<div class="modal fade" id="FormModal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-info text-white">
                <h5 class="modal-title" id="exampleModalLabel">Usuario</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="form">
                    <input id="txtid" class="model" value="0" type="hidden" />
                    <input id="txtNom_Rol" class="model" value="USUARIO" type="hidden" />
                    <div class="mb-3 row">

                        <label for="inputCedula" class="col-sm-3 col-form-label col-form-label-sm">Identificación</label>
                        <div class="col-sm-8">
                            <select class="form-control form-control-sm model" id="cboTipoDocumento" name="cboTipoDocumento">
                                <option value="DNI">Cédula Nacional</option>
                                <option value="Carnet Extranjeria">Carnet Extranjeria</option>
                            </select>
                        </div>
                    </div>
                    <div class="mb-3 row">
                        <label for="inputCedula" class="col-sm-3 col-form-label col-form-label-sm">Identificación</label>
                        <div class="col-sm-8">
                            <input type="number" class="form-control form-control-sm model" id="inputCedula" name="Cedula">
                            <!-- Mensaje de error -->

                        </div>
                    </div>
                    <div class="mb-3 row ">
                        <label for="txtNombre" class="col-sm-3 col-form-label col-form-label-sm">Nombre</label>
                        <div class="col-sm-8">
                            <input type="text" class="form-control form-control-sm model" id="txtNombre" name="Nom_Completo">
                            <!-- Mensaje de error -->
                        </div>

                    </div>
                    <div class="mb-3 row">
                        <label for="txtNom_User" class="col-sm-3 col-form-label col-form-label-sm">Usuario</label>
                        <div class="col-sm-8">
                            <input type="text" class="form-control form-control-sm model" id="txtNom_User" name="Nom_User">
                            <!-- Mensaje de error -->

                        </div>
                    </div>

                    <div class="mb-3 row">
                        <label for="txtCorreo" class="col-sm-3 col-form-label col-form-label-sm">Correo</label>
                        <div class="col-sm-8">
                            <input type="text" class="form-control form-control-sm model" id="txtCorreo" name="Correo" placeholder="Formato correo Ej. correo@dominio.com">
                            <!-- Mensaje de error -->
                            <span class="text-danger small error-message d-block mt-1"></span>
                        </div>
                    </div>

                    <input class="model" id="txtClave" type="hidden" />


                    <div class="mb-3 row">
                        <label for="cboRol" class="col-sm-3 col-form-label col-form-label-sm">Rol</label>
                        <div class="col-sm-8">
                            <select class="form-control form-control-sm model" id="cboRol" name="Rol"></select>
                        </div>
                    </div>

                    <input type="hidden" class="form-control form-control-sm model" id="txtNom_Rol" name="Nom_Rol" />

                    <div class="mb-3 row">
                        <label for="cboEstado" class="col-sm-3 col-form-label col-form-label-sm">Activo</label>
                        <div class="col-sm-8">
                            <select class="form-control form-control-sm model" id="cboEstado" name="Activo">
                                <option value="1">Activo</option>
                                <option value="0">No Activo</option>
                            </select>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-sm btn-danger" data-bs-dismiss="modal">Cerrar</button>
                <button id="btnGuardarCambios" type="button" class="btn btn-sm btn-primary" onclick="Guardar()">Guardar</button>
            </div>
        </div>
    </div>
</div>



@section scripts{
    <script src="@Url.Content("~/Scripts/Views/Vista_usuario.js")" type="text/javascript"></script>
}





