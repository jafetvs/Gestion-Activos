
@{
    ViewBag.Title = "EditarUsuario";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<style>
    /* ===================== */
    /* GENERAL LABEL STYLING */
    /* ===================== */
    label {
        display: inline-block;
        max-width: 100%;
        margin-bottom: 5px;
        font-weight: 700;
    }

    /* ===================== */
    /* PAGE HEADER           */
    /* ===================== */
    .page-header {
        padding-bottom: 9px;
        margin: 40px 0 20px;
        border-bottom: 1px solid #eee;
    }

    /* ===================== */
    /* BREADCRUMB NAVIGATION */
    /* ===================== */
    .breadcrumb {
        padding: 8px 15px;
        margin-bottom: 20px;
        list-style: none;
        background-color: #f5f5f5;
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }

        .breadcrumb > li {
            display: flex;
            align-items: center;
            gap: 5px;
        }

    /* ===================== */
    /* FONT AWESOME ICONS    */
    /* ===================== */
    .fa {
        display: inline-block;
        font: normal normal normal 14px/1 FontAwesome;
        text-rendering: auto;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        vertical-align: middle;
        font-size: 16px; /* Ajustable */
        margin-right: 5px;
    }

    /* ===================== */
    /* LINKS                 */
    /* ===================== */
    a {
        color: #337ab7;
        text-decoration: none;
    }

    /* ===================== */
    /* PASSWORD CONTAINER    */
    /* ===================== */
    .password-container {
        margin-bottom: 1.5rem;
    }

    .input-wrapper {
        position: relative;
        width: 100%;
    }

        .input-wrapper input {
            padding-right: 40px;
            height: 38px;
        }

    .toggle-password {
        position: absolute;
        right: 10px;
        top: 0;
        bottom: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        background: none;
        border: none;
        cursor: pointer;
        font-size: 18px;
        color: #000;
        padding: 0;
    }



        .toggle-password i {
            pointer-events: none;
        }

    /* ===================== */
    /* ERROR TEXT            */
    /* ===================== */
    span.text-danger {
        font-size: 0.875rem;
        color: red;
        margin-top: 0.25rem;
        display: block;
        position: relative;
        z-index: 1;
    }
    .text-danger {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 0.875rem;
        color: red;
        margin-top: 0.25rem;
        position: relative;
        z-index: 1;
        line-height: 1.4;
    }

        .text-danger i.fa {
            font-size: 14px;
            vertical-align: middle;
        }



   
</style>
<div id="page-wrapper">
    <div class="container-fluid">
        <div id="UpdatePanel1">
            <!-- Page Heading -->
            <div class="row">
                <div class="col-lg-12">
                    <h3 class="page-header">
                        <span id="chpPrincipal_lblTitulo">Detalles del Usuarios </span>
                    </h3>
                    <ol class="breadcrumb">
                        <li class="me-3">
                            <i class="fas fa-address-card"></i> <a href="@Url.Action("usuario", "Usuario")">Usuarios</a>
                        </li>
                        <li class="active me-3">
                            <i class="fa fa-adjust"></i> <a href="@Url.Action("permisos", "Permisos")">Permisos</a>
                        </li>
                    </ol>

                </div>
                <div class="col-lg-12">
                    <div class="wrapper text-center">
                        <span id="chpPrincipal_lblMensaje" class="error-msg"></span>
                        <div id="chpPrincipal_valMensajes" class="error-msg" style="display:none;">
                            <!-- Mensajes de error -->
                        </div>
                    </div>
                </div>
                <div class="tab-content">
                    <div id="sectionA">
                        <div class="row">
                            <div class="col-lg-12">
                                <br />
                            </div>
                        </div>
                        <form id="form">
                            <div class="row">
                                <div class="col-lg-4">
                                    <div class="mb-3">
                                        <label for="txtIdentificacion" class="form-label">Código Usuario</label>
                                        <div class="input-group">
                                            <input name="txtinputCedula" type="text" value=""
                                                   id="inputIdUsuario" disabled class="form-control" />
                                        </div>
                                    </div>
                                    <div class="mb-3">
                                        <label for="txtIdentificacion" class="form-label">Identificación</label>
                                        <div class="input-group">
                                            <input name="txtinputCedula" type="text" value=""
                                                   id="inputCedula" disabled class="form-control" />
                                        </div>
                                    </div>
                                    <div class="mb-3">
                                        <label for="txtNombre" class="form-label">Nombre Completo</label>
                                        <input type="text" class="form-control" id="txtNombre">
                                    </div>
                                    <div class="mb-3">
                                        <label for="#txtNombre_User" class="form-label">Nombre de Usuario</label>
                                        <input type="text" class="form-control" id="txtNombre_User">
                                    </div>

                                    <div class="mb-3">
                                        <label for="txtEstado" class="form-label">Estado usuario</label>
                                        <select class="form-control form-control-sm model" id="cboEstado" name="Activo">
                                            <option value="1">Activo</option>
                                            <option value="0">No Activo</option>
                                        </select>
                                    </div>
                                    <div class="mb-3">
                                        <label for="txtCorreo" class="form-label">Correo Electrónico</label>
                                        <input type="email" class="form-control" id="txtCorreo" placeholder="Formato correo Ej. correo@dominio.com">
                                    </div>

                                </div>

                                <div class="col-lg-4">
                                    <div class="mb-3">
                                        <label for="inputTelefono" class="form-label">Teléfono 1</label>
                                        <input type="text" class="form-control" id="inputTelefono" placeholder="Ingrese teléfono" />
                                    </div>

                                    <div class="mb-3">
                                        <label for="txtTelefono" class="form-label">Teléfono 2</label>
                                        <input name="inputTelefono2" type="text" maxlength="20" id="inputTelefono2"
                                               class="form-control" placeholder="Ingrese teléfono" />
                                    </div>

                                    <div class="mb-3">
                                        <label for="inputFax" class="form-label">Fax</label>
                                        <input type="text" class="form-control" id="inputFax" placeholder="Ingrese Fax" />
                                    </div>
                                    <div class="mb-3">
                                        <label for="cboRol" class="form-label">Rol</label>
                                        <select class="form-control form-control-sm model" id="cboRol" name="Rol"></select>
                                    </div>
                                    <input type="hidden" class="form-control form-control-sm model" id="txtNom_Rol" name="Nom_Rol" />

                                    <div class="mb-3">
                                        <label for="txtDireccion" class="form-label">Dirección</label>
                                        <textarea class="form-control" id="txtDireccion" rows="4" cols="20" placeholder="Ingrese dirección"></textarea>
                                    </div>
                                </div>

                                <div class="col-lg-4">
                                    <div class="mb-3">
                                        <label for="chpPrincipal_txtImagen" class="form-label">Fotografía:</label>
                                        <img id="chpPrincipal_txtImagen" class="img-responsive" alt="No disponible." src="~/Imagenes/NODISPONIBLE.jpg" style="height:103px;width:111px;" />

                                    </div>

                                    <div class="mb-3">
                                        <label for="chpPrincipal_RadAsyncUpload1" class="form-label">Seleccionar archivo</label>
                                        <div id="ctl00_chpPrincipal_RadAsyncUpload1" class="RadAsyncUpload RadUpload RadUpload_Default">
                                            <input id="ctl00_chpPrincipal_RadAsyncUpload1_ClientState" name="ctl00_chpPrincipal_RadAsyncUpload1_ClientState" type="hidden" />
                                        </div>
                                        <button type="submit" class="btn btn-danger btn-sm" id="chpPrincipal_btnSubirFoto">Enviar</button>
                                    </div>
                                    <div class="mb-3">
                                        <label for="txtFechaRegistro" class="form-label">Fecha de Registro</label>
                                        <input type="text" class="form-control" id="txtFechaRegistro" readonly>
                                    </div>




                                    <div class="form-group password-container">
                                        <label for="inputPassword">Contraseña</label>

                                        <div class="input-wrapper">
                                            <input type="password" class="form-control" id="inputPassword" name="inputPassword" />
                                            <button type="button" class="toggle-password" onclick="togglePassword('inputPassword', 'icon1')">
                                                <i id="icon1" class="fas fa-lock"></i>
                                            </button>
                                        </div>

                                        <span class="text-danger" id="errorPassword"></span>
                                    </div>

                                    <div class="mb-3 password-container">
                                        <label for="inputPasswordConfirm" class="form-label">Confirme Contraseña</label>

                                        <div class="input-wrapper">
                                            <input name="inputPasswordConfirm" type="password" maxlength="50" class="form-control"
                                                   id="inputPasswordConfirm" placeholder="Confirme contraseña" autocomplete="new-password" required />

                                            <button type="button" class="toggle-password" onclick="togglePassword('inputPasswordConfirm', 'icon2')">
                                                <i id="icon2" class="fas fa-lock"></i>
                                            </button>
                                        </div>

                                        <span class="text-danger" id="errorPasswordConfirm"></span>
                                    </div>

                                </div>
                            </div>

                            <!-- /.row -->
                            <div class="row">
                                <div class="col-lg-12">
                                    <div class='wrapper text-center'>
                                        <div class="btn-group">
                                            <button id="btnGuardarCaso" type="button" class="btn btn-success" onclick="Guardar()">Actializar</button>

                                        </div>
                                        <div class="btn-group">
                                            <button id="btnGuardarCaso" type="button" class="btn btn-success" onclick="Cancelar()">Cancelar</button>
                                        </div>
                                    </div>

                                </div>
                            </div>
                            <!-- /.row -->
                        </form>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>


@section scripts{
    <script src="@Url.Content("~/Scripts/Views/Vista_EditarUsuario.js")" type="text/javascript"></script>
    <script src="@Url.Content("~/Scripts/Views/Vista_Login.js")" type="text/javascript"></script>

}





