
@{
    ViewBag.Title = "permisos";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@section estilos{
    <style>
        #tbpermiso tbody {
            display: block;
            max-height: 300px;
            overflow: auto;
        }

            #tbpermiso thead, #tbpermiso tbody tr {
                display: table;
                width: 100%;
                table-layout: fixed;
            }

        #tbpermiso tbody {
            width: 100%;
        }

        #tbpermiso thead {
            width: 99%;
        }

        .custom-header {
            background-color: #53a87c; /* Color de fondo deseado */
            color: white; /* Color del texto */
            padding: 10px; /* Opcional: añadir espaciado */
            border-radius: 4px; /* Opcional: bordes redondeados */
            text-align: center; /* Opcional: centrar texto */
        }
    </style>
}

<div class="col-lg-12 mt-4">
    <h3 class="page-header">
        <span id="chpPrincipal_lblTitulo">Configuración de Permisos </span>
    </h3>
    <ol class="breadcrumb">
        <li class="me-3">
            <i class="fas fa-users-cog me-1"></i>
            <a href="@Url.Action("usuario", "Usuario")" style="text-decoration: none;">Usuarios</a>
        <li class="active me-3">
            <i class="fas fa-users me-1"></i>
            <a href="@Url.Action("rol", "Rol")" style="text-decoration: none;">Roles</a>
        </li>
    </ol>
</div>
<div class="row">
    <div class="col-sm-12">
        <div class="card border-info">

            <div class="card-header custom-header">
                Asignar Permisos
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-sm-2">
                        <label>Seleccion Rol:</label>
                    </div>
                    <div class="col-sm-3">
                        <select class="form-control form-control-sm model" id="cboRol" name="Activo"></select>
                    </div>
                    <div class="col-sm-2">
                        <button id="btnBuscar" type="button" class="btn btn-sm btn-primary btn-block" onclick="buscar()"> <i class="fas fa-search"></i> Buscar</button>
                    </div>
                    <div class="col-sm-2">
                        <button id="btnGuardarCambios" class="btn btn-sm btn-success btn-block" onclick="Guardar()"><i class="fas fa-save"></i> Guardar Cambios</button>
                    </div>
                </div>
                <hr />
                <div class="row mt-3 card-load">
                    <div class="col-sm-12">
                        <div class="table-responsive">
                            <table id="tbpermiso" class="table table-bordered table-sm" style="width:100%">
                                <thead>
                                    <tr>
                                        <th>#</th>
                                        <th>Activar</th>
                                        <th>Menu</th>
                                        <th>Sub Menu</th>
                                    </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section scripts{
    <script src="@Url.Content("~/Scripts/Views/Vista_Permisos.js")" type="text/javascript"></script>
}





